rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && (request.auth.token.email == 'djdeeroy@gmail.com'
          || (exists(/databases/$(database)/documents/community_profiles/$(request.auth.uid))
            && (get(/databases/$(database)/documents/community_profiles/$(request.auth.uid)).data.accessRole == 'admin'
              || get(/databases/$(database)/documents/community_profiles/$(request.auth.uid)).data.role == 'admin')));
    }

    function isModerator() {
      return isAdmin()
        || (request.auth != null
          && exists(/databases/$(database)/documents/community_profiles/$(request.auth.uid))
          && get(/databases/$(database)/documents/community_profiles/$(request.auth.uid)).data.accessRole == 'moderator');
    }

    match /live_feed_posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          'authorId', 'authorName', 'authorImageUrl', 'text', 'imageUrl',
          'reactions', 'reactionBy', 'createdAt'
        ])
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorName is string
        && request.resource.data.authorImageUrl is string
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 2000
        && request.resource.data.imageUrl is string
        && request.resource.data.reactions is map
        && request.resource.data.reactionBy is map
        && (request.auth.token.firebase.sign_in_provider != 'anonymous'
            || request.resource.data.imageUrl == '');
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'reactions', 'reactionBy'
        ])
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.text == resource.data.text
        && request.resource.data.imageUrl == resource.data.imageUrl
        && request.resource.data.reactions is map
        && request.resource.data.reactionBy is map;
      allow delete: if isModerator();
    }

    match /community_profiles/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null
        && request.auth.uid == userId
        && (isAdmin()
            || (request.resource.data.role in ['dj', 'organizer', 'partygoer']
              && (!request.resource.data.keys().hasAny(['accessRole'])
                || request.resource.data.accessRole == 'none')));
      allow update: if request.auth != null
        && ((request.auth.uid == userId
          && (request.resource.data.role == resource.data.role
            || (!resource.data.keys().hasAny(['role'])
                && request.resource.data.role in ['dj', 'organizer', 'partygoer']))
          && (!request.resource.data.keys().hasAny(['accessRole'])
            || request.resource.data.accessRole == resource.data.accessRole))
          || (isAdmin()
            && request.resource.data.role in ['dj', 'organizer', 'partygoer']
            && (!request.resource.data.keys().hasAny(['accessRole'])
              || request.resource.data.accessRole in ['none', 'moderator', 'admin'])));
    }
  }
}
